#!/usr/bin/env bash
# Drafty launcher. While the plugin is enabled this is on the Bash tool's PATH,
# so `drafty <command>` just works — no separate `setup` step. Runs under bun
# (https://bun.sh) or Node ≥22.18 — whichever is on PATH.
#
# Self-resolving shim: rather than run *this* copy's CLI, it finds the newest
# installed plugin version in the cache and runs that. So a plugin update is
# picked up on the very next `drafty` call without a `/reload-plugins` — Claude
# Code pins the on-PATH launcher to its version dir, but this launcher doesn't
# care which dir it lives in; it always execs the latest one on disk.
set -euo pipefail

self="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"   # .../<version>/bin
base="$(cd "$self/../.." && pwd)"                       # .../drafty-im/drafty (holds version dirs)

# Newest installed version dir (semver order). Empty if the layout isn't the
# versioned cache (e.g. running straight from a git checkout).
# `|| true` so a no-match grep (a dev checkout with no version dirs) doesn't trip
# `set -e`/`pipefail` — we want to fall through to the fallback below, not abort.
newest="$(ls -1 "$base" 2>/dev/null | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1 || true)"
root="$base/$newest"

# Fall back to this copy's own dir if we couldn't resolve a newer one (dev
# checkout, unexpected layout, or a half-cleaned cache) — never worse than before.
if [ -z "$newest" ] || [ ! -f "$root/cli/canvas.ts" ]; then
  root="$(cd "$self/.." && pwd)"
fi

# Runtime: prefer bun (the historical runtime — what existing installs already
# have, fastest start), else Node ≥22.18 / 23.6+ / 24+, which runs single-file
# TypeScript natively (the flag silences the type-stripping ExperimentalWarning
# on the 22.x line). Claude Code's native installer guarantees NEITHER runtime,
# so when both are missing the error must say exactly what to install.
if command -v bun >/dev/null 2>&1; then
  exec bun "$root/cli/canvas.ts" "$@"
fi
if command -v node >/dev/null 2>&1; then
  v="$(node --version 2>/dev/null || true)"; v="${v#v}"
  major="${v%%.*}"; rest="${v#*.}"; minor="${rest%%.*}"
  if [ "${major:-0}" -ge 24 ] 2>/dev/null \
     || { [ "${major:-0}" -eq 23 ] && [ "${minor:-0}" -ge 6 ]; } 2>/dev/null \
     || { [ "${major:-0}" -eq 22 ] && [ "${minor:-0}" -ge 18 ]; } 2>/dev/null; then
    exec node --disable-warning=ExperimentalWarning "$root/cli/canvas.ts" "$@"
  fi
  echo "drafty: your node (v$v) is too old to run TypeScript directly — needs Node >=22.18 (https://nodejs.org), or install bun (https://bun.sh)." >&2
  exit 127
fi
echo "drafty: needs Node >=22.18 (https://nodejs.org) or bun (https://bun.sh) on PATH." >&2
exit 127
